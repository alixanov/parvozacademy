# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
client/dist/
/build

# ── Environment variables (NEVER commit secrets) ──────────────────────────────
# Server .env has secrets (JWT, DB, storage keys) — never commit
server/.env
.env
.env.local
.env.*.local
# Client .env.development and .env.production are safe (no secrets) — committed

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
server/server.log
server/server.err
server/server_debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Uploaded files (must never go into client/public or repo root) ────────────
client/public/*.pdf
client/public/*.docx
client/public/*.xlsx
uploads/

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage
/.pnp
.pnp.js
