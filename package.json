{
  "name": "parvoz-academy-lms",
  "version": "1.0.0",
  "private": true,
  "description": "PARVOZ ACADEMY — Monorepo (client + server)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "cd client && npm ci && npm run build",
    "start": "node server/server.js",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "cd client && npm ci && cd ../server && npm ci"
  }
}
