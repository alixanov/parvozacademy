# ══════════════════════════════════════════════════════════════════════════════
# PARVOZ ACADEMY — Server Environment Variables
# Copy to .env for local development. Set these directly in Railway dashboard.
# ══════════════════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production (Railway single-service), frontend is served from same origin
# so CLIENT_URL is optional. Set it only if you deploy frontend separately.
# Supports comma-separated list: CLIENT_URL=https://a.com,https://b.com
CLIENT_URL=http://localhost:3000

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Railway MongoDB: copy the "Internal URL" from your Railway MongoDB service
# Atlas:           mongodb+srv://user:pass@cluster.mongodb.net/parvoz_academy
MONGODB_URI=mongodb://localhost:27017/parvoz_academy

# ── JWT ────────────────────────────────────────────────────────────────────────
# Use a strong random string (min 32 chars) — generate: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── T3 Storage (S3-compatible) ─────────────────────────────────────────────────
T3_ACCESS_KEY_ID=your_t3_access_key_id
T3_SECRET_ACCESS_KEY=your_t3_secret_access_key
T3_ENDPOINT=https://t3.storage.dev
T3_BUCKET=your-bucket-name

# ── Super Admin (used by seed.js only) ────────────────────────────────────────
SUPER_ADMIN_NAME=Admin Name
SUPER_ADMIN_PHONE=+998901234567
SUPER_ADMIN_PASSWORD=strongpassword123

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
